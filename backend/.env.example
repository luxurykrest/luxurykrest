# Supabase Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the "Connection pooling" (port 6543) string, not the direct one — Render's
# environment works better with the pooled connection.
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Gmail sender used for OTP + notification emails.
# GMAIL_APP_PASSWORD is a 16-char Google "App Password", not your normal password.
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Secret key required in the x-admin-key header for /api/admin/* routes.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=replace-with-a-long-random-string

# Comma-separated list of exact origins allowed to call this API.
ALLOWED_ORIGINS=https://e1awadi.com,https://www.e1awadi.com

# Render sets this automatically — safe to leave unset locally.
PORT=3000

# Set to "production" on Render so OTP codes stop being logged.
NODE_ENV=development
